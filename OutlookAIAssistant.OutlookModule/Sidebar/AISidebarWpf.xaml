<UserControl x:Class="OutlookAIAssistant.OutlookModule.Sidebar.AISidebarWpf"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" MinHeight="200">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="AI Assistant" FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,8" />

        <!-- Quick Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Button x:Name="btnSummarize" Content="Summarize" Width="80" Height="28" Margin="0,0,4,0" />
            <Button x:Name="btnReply" Content="Reply" Width="80" Height="28" Margin="4,0,4,0" />
            <Button x:Name="btnClassify" Content="Classify" Width="80" Height="28" Margin="4,0,0,0" />
        </StackPanel>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="txtResult" Text="Select an email and click an action above."
                       TextWrapping="Wrap" FontSize="13" />
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#F0F0F0" Padding="4" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtStatus" Text="Ready" FontSize="11" Foreground="Gray" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>